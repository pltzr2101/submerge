# Submerge configuration
# Copy this file to .env and adjust values as needed.

# --- Required ---
# Language pairs (bottom-top), comma-separated. Example: de-ko,en-ko
SUBTOOLS_PAIRS=de-ko

# --- Media ---
# Root directory for media files (container path)
SUBTOOLS_MEDIA_ROOT=/data

# --- Behavior ---
# Polling interval in seconds for retry checks (10-3600)
SUBTOOLS_POLL_INTERVAL=60

# Abandon pending merges after this many hours
SUBTOOLS_RETRY_TIMEOUT_H=48

# --- Styling: Bottom track (e.g., German) ---
SUBTOOLS_COLOR_BOTTOM=#FFFFFF
SUBTOOLS_BOTTOM_OUTLINE_COLOR=#000000
SUBTOOLS_BOTTOM_OUTLINE=2.0
SUBTOOLS_BOTTOM_SHADOW=1.0
SUBTOOLS_BOTTOM_BOLD=false
SUBTOOLS_BOTTOM_MARGIN_V=20
SUBTOOLS_BOTTOM_MARGIN_H=20
SUBTOOLS_BOTTOM_SPACING=0.0
SUBTOOLS_BOTTOM_FONTSIZE=22
SUBTOOLS_FONT_BOTTOM=

# --- Styling: Top track (e.g., Korean) ---
SUBTOOLS_COLOR_TOP=#FFD700
SUBTOOLS_TOP_OUTLINE_COLOR=#000000
SUBTOOLS_TOP_OUTLINE=2.0
SUBTOOLS_TOP_SHADOW=1.0
SUBTOOLS_TOP_BOLD=false
SUBTOOLS_TOP_MARGIN_V=20
SUBTOOLS_TOP_MARGIN_H=20
SUBTOOLS_TOP_SPACING=0.0
SUBTOOLS_TOP_FONTSIZE=22
# CJK font for top track (important for Korean/Chinese/Japanese)
SUBTOOLS_FONT_TOP=Noto Sans KR

# --- Layout ---
# Layout: top-bottom (one at top, one at bottom) or stacked (both at bottom)
SUBTOOLS_LAYOUT=top-bottom
# Gap between stacked subtitle lines (4-200)
SUBTOOLS_STACKED_GAP=40

# --- Web UI ---
# Username for basic auth
SUBTOOLS_UI_USER=admin
# Password for basic auth (empty = no authentication)
SUBTOOLS_UI_PASSWORD=

# Max requests per minute per IP (0 = disabled)
SUBTOOLS_RATE_LIMIT_RPM=30
